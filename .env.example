# ============================================
# Deep Research From Scratch - Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================

# Required for research agents with external search
TAVILY_API_KEY=your_tavily_api_key_here

# Required for Google Gemini models (primary model used)
GOOGLE_API_KEY=your_google_api_key_here

# Product backend and self-hosted stack
DATABASE_URL=postgresql+psycopg://copilot:copilot@postgres:5432/copilot
JWT_SECRET=change_me_for_local_dev
INVITE_SECRET=change_me_for_invites
APP_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001
ARTIFACTS_DIR=/app/artifacts

# Optional: For LangSmith evaluation and tracing
# LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=deep_research_from_scratch
